float4x4 makeRotationMatrixX(float x)
{
    return float4x4(1,       0,       0, 0,
                    0,  cos(x), -sin(x), 0,
                    0,  sin(x),  cos(x), 0,
                    0,       0,       0, 1);
}

// get segm map value for the 2d lm position
float GetSegmValue(float2 lmPos)
{
    int ix = (int)(lmPos.x * _segmInputWidth);
    int iy = (int)((1.0 - lmPos.y) * _segmInputHeight);
    int ind = ix + iy * _segmInputWidth;

    if(ix < 0 || ix >= _segmInputWidth || iy < 0 || iy >= _segmInputHeight)
        return -1.0;
    else
        return _segmInputBuffer[ind];
}

[numthreads(39 + 1, 1, 1)]
void LmProcessLandmarks(uint id : SV_DispatchThreadID)
{   
    if(id > _landmarkCount) 
		return;

    PoseRegion region = _poseRegions[_poseIndex];

    if(id == _landmarkCount)
	{
        float poseConfidence = _poseFlag[0];

        //_landmarkOutput[id] = float4(poseConfidence, 0, 0, 0);
        float2 boxPos = (region.box.xy - 0.5) * _lboxScale + 0.5;
        float2 boxSize = region.size.xy * _lboxScale;
        _landmarkOutput[id] = float4(boxPos, boxSize);

        _landmarkWorldOutput[id] = float4(poseConfidence, 0, 0, 0);
        _landmarkSensorOutput[id] = float4(poseConfidence, 0, 0, 0);
    }
    else
	{
        float x = _landmarkInput[id * 5] / LM_IMAGE_SIZE;
        float y = _landmarkInput[id * 5 + 1] / LM_IMAGE_SIZE;
        //float z = _landmarkInput[id * 5 + 2] / LM_IMAGE_SIZE;

        float visibility = _landmarkInput[id * 5 + 3];
        float presence = _landmarkInput[id * 5 + 4];

        float scoreV = Sigmoid(visibility);
        float scoreP = Sigmoid(presence);
        float score = id <= 32 ? min(scoreV, scoreP) : scoreP;

        //// refine lm from heatmap
        //if(_HmWidth > 0 && _HmHeight > 0 && _KernelSize > 0 && 
        //    x >= 0.0 && x < 1.0 && y >= 0.0 && y < 1.0)
        //{
        //    uint offset = (_KernelSize - 1) / 2;
        //    uint centerCol = (uint)(x * _HmWidth);
        //    uint centerRow = (uint)(y * _HmHeight);

        //    uint beginCol = max(0, centerCol - offset);
        //    uint endCol = min(_HmWidth, centerCol + offset + 1);
        //    uint beginRow = max(0, centerRow - offset);
        //    uint endRow = min(_HmHeight, centerRow + offset + 1);

        //    float totalSum = 0.0;
        //    float weightedCol = 0.0;
        //    float weightedRow = 0.0;

        //    float maxConfidence = 0.0;
        //    for(uint row = beginRow; row < endRow; row++)
        //        for(uint col = beginCol; col < endCol; col++)
        //        {
        //            int index = (row * _HmWidth + col) * id.x;
        //            float confidence = Sigmoid(_Heatmap[index]);

        //            totalSum += confidence;
        //            weightedCol += col * confidence;
        //            weightedRow += row * confidence;

        //            maxConfidence = max(maxConfidence, confidence);
        //        }

        //    if(maxConfidence >= _MinConfidence && totalSum > 0)
        //    {
        //        x = weightedCol / _HmWidth / totalSum;
        //        y = weightedRow / _HmHeight / totalSum;
        //    }
        //}

        float3 pos = float3(x, 1.0 - y, 0);
        float segm = GetSegmValue(pos.xy);

        pos = mul(region.cropMatrix, float4(pos, 1)).xyz;
        pos.xy = (pos.xy - 0.5) * _lboxScale + 0.5;
        _landmarkOutput[id] = float4(pos.xy, segm, score);

        float2 lmUv = float2(pos.x, 1.0 - pos.y);
		uint dx = (uint)(lmUv.x * _depthMapWidth);
		uint dy = (uint)(lmUv.y * _depthMapHeight);

        pos = float3(_landmarkWorldInput[id * 3], -_landmarkWorldInput[id * 3 + 1], _landmarkWorldInput[id * 3 + 2]);

        float4x4 rotationMat = mul(makeRotationMatrixZ(region.box.w), makeRotationMatrixX(LM_TILT));
        pos = mul(rotationMat, float4(pos, 1)).xyz;
        _landmarkWorldOutput[id] = float4(pos, score);

        float4 lmPos = float4(0, 0, 0, score);
        if(_intrFlen.x != 0 && _intrFlen.y != 0)
        {
            float x = (dx - _intrPpt.x) / _intrFlen.x;  // * pos.z;
            float y = (dy - _intrPpt.y) / _intrFlen.y;  // * pos.z;
            lmPos = float4(x, y, 1, score);  // pos.z, score);
        }

        _landmarkSensorOutput[id] = lmPos;

        if(id == 33)
        {
		    uint di = clamp(dx, 0, _depthMapWidth - 1) + clamp(dy, 0, _depthMapHeight - 1) * _depthMapWidth;
				
		    uint depth2 = _depthMapBuf[di >> 1];
		    uint depthMm = (dx & 1) != 0 ? depth2 >> 16 : depth2 & 0xffff;
            float depth = depthMm * 0.001;

            float4 hipPos = float4(0, 0, 0, score);
            if(_intrFlen.x != 0 && _intrFlen.y != 0)
            {
                float x = (dx - _intrPpt.x) / _intrFlen.x * depth;
                float y = (dy - _intrPpt.y) / _intrFlen.y * depth;
                hipPos = float4(x, -y, depth, score);
            }

            _landmarkWorldOutput[id] = hipPos;
        }
    }
}


