// detection input image size
#define DET_IMAGE_SIZE 640

// detection input image size
//#define DET_IMAGE_SIZE 224
// landmark input image size
#define LM_IMAGE_SIZE 256

// max allowed detections and number of detected bodies
#define MAX_DETECTIONS 100
#define MAX_BODIES 3
//#define BODY_SIZE_SCALE 2.1

// math.pi & lm tilt (5 deg back)
#define PI 3.14159265359
#define LM_TILT 5 * PI / 180


float Sigmoid(float x)
{
    return 1.0 / (1.0 + exp(-x));
}


float _scoreThreshold;
RWStructuredBuffer<PoseDetection> _detInput;
AppendStructuredBuffer<PoseDetection> _detOutput;

[numthreads(50, 1, 1)]
void ProcessDetections(uint3 id : SV_DispatchThreadID)
{
    const float scale = 1.0 / DET_IMAGE_SIZE;
    PoseDetection pd = _detInput[id.x];

    if (pd.score >= _scoreThreshold)
    {
        pd.center *= scale;
        pd.size *= scale;

        [unroll]
		for(uint kp = 0; kp < KP_COUNT; kp++)
		{
            pd.keypoints[kp] *= scale;
        }

		_detOutput.Append(pd);
    }
}

