float _iouThreshold;
ConsumeStructuredBuffer<PoseDetection> _nmsInputBuf;
ByteAddressBuffer _nmsCountBuf;
AppendStructuredBuffer<PoseDetection> _nmsOutputBuf;
groupshared PoseDetection _nmsPoseArray[MAX_DETECTIONS];
groupshared bool _nmsKeepArray[MAX_DETECTIONS];

//RWStructuredBuffer<PoseDetection> _nmsPoseBuffer;
//RWStructuredBuffer<bool> _nmsKeepBuffer;
//RWStructuredBuffer<float> _nmsIouBuffer;
//RWStructuredBuffer<bool> _nmsScoreBuffer;

// caluculate IOU between boxes.
float CalcIOU(in PoseDetection pd1, in PoseDetection pd2)
{
    float pd1Area = pd1.size.x * pd1.size.y;
    float pd2Area = pd2.size.x * pd2.size.y;

    float2 p0 = max(pd1.center - pd1.size * 0.5, pd2.center - pd2.size * 0.5);
    float2 p1 = min(pd1.center + pd1.size * 0.5, pd2.center + pd2.size * 0.5);
    float innerArea = max(0, p1.x - p0.x) * max(0, p1.y - p0.y);

    return innerArea / (pd1Area + pd2Area - innerArea);
}

// calculate batched NMS
[numthreads(1, 1, 1)]
void DetectBatchedNMS(uint3 id : SV_DispatchThreadID)
{
    int inputCount = _nmsCountBuf.Load(0);
    inputCount = min(inputCount, MAX_DETECTIONS);

    for(int i1 = 0; i1 < inputCount; i1++)
	{
        _nmsPoseArray[i1] = _nmsInputBuf.Consume();
        //_nmsPoseBuffer[i] = _nmsPoseArray[i];
    }

    for(int i2 = 0; i2 < inputCount; i2++)
    {
        bool isKeep = true;

        [unroll]
        for (int j = 0; j < i2; j++)
        {
            if(_nmsKeepArray[j])
            {
                float iou = CalcIOU(_nmsPoseArray[i2], _nmsPoseArray[j]);

                //_nmsIouBuffer[i2 * inputCount + j] = iou;
                //_nmsScoreBuffer[i2 * inputCount + j] = _nmsPoseArray[i2].score > _nmsPoseArray[j].score;

                if(iou >= _iouThreshold)
                {
                    if(_nmsPoseArray[i2].score > _nmsPoseArray[j].score)
                    {
                        _nmsKeepArray[j] = false;
                        //_nmsKeepBuffer[j] = false;
                    }
                    else
                    {
                        isKeep = false;
                        break;
                    }
                }
            }
        }

        _nmsKeepArray[i2] = isKeep;
        //_nmsKeepBuffer[i2] = isKeep;
    }

    int outputCount = 0;
    for (int i3 = 0; (i3 < inputCount) && (outputCount < MAX_BODIES); i3++)
    {
        if(_nmsKeepArray[i3])
        {
            PoseDetection pd1 = _nmsPoseArray[i3];
            float pd1Max = max(pd1.size.x, pd1.size.y);
            float pd1Val = (pd1Max - abs(pd1.center.x - 0.5)) + (pd1Max - abs(pd1.center.y - 0.5)) + pd1.size.x + pd1.size.y;

            for(int j3 = i3 + 1; j3 < inputCount; j3++)
            {
                if(_nmsKeepArray[j3])
                {
                    PoseDetection pd2 = _nmsPoseArray[j3];
                    float pd2Max = max(pd2.size.x, pd2.size.y);
                    float pd2Val = (pd2Max - abs(pd2.center.x - 0.5)) + (pd2Max - abs(pd2.center.y - 0.5)) + pd2.size.x + pd2.size.y;

                    if(pd2Val > pd1Val)
                    {
                        _nmsPoseArray[j3] = pd1;
                        _nmsPoseArray[i3] = pd2;

                        pd1 = pd2;
                        pd1Val = pd2Val;
                    }
                }
            }

            _nmsOutputBuf.Append(pd1);
            outputCount++;
        }
    }
}


