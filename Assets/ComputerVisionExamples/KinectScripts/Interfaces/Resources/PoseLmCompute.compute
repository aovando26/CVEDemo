// get the body-index value of the given coordinates
uint GetBodyIndexOf(uint idX, uint idY, uint biShift, uint biMask)
{
	float u = (float)(_DepthScaleX >= 0.0 ? idX : _BodyIndexImgWidth - idX - 1) / _BodyIndexImgWidth;
	float v = (float)(_BodyIndexImgHeight - idY - 1) / _BodyIndexImgHeight;

	float2 imgUv = float2(u, v);
	PoseRegion region = _poseRegions[_poseIndex];

	float2 texUv = (imgUv - 0.5) * _InvScale + 0.5;
	texUv = mul(region.invMatrix, float4(texUv, 0, 1)).xy;
	int2 texXy = int2(texUv.x * _SegmTexWidth, (1 - texUv.y) * _SegmTexHeight);

	uint bi = 0xffffffff;
    if(texXy.x >= 0 && texXy.x < _SegmTexWidth && texXy.y >= 0 && texXy.y < _SegmTexHeight)
    {
        int segmIdx = texXy.x + texXy.y * _SegmTexWidth;

	    if (_SegmBuf[segmIdx] > 0)
	    {
            bi = (_poseIndex << biShift) | biMask;

		    //switch (idX & 3)
		    //{
			//    case 0:
			//	    bi = 0xffffff00 | _poseIndex;
			//	    break;
			//    case 1:
			//	    bi = 0xffff00ff | (_poseIndex << 8);
			//	    break;
			//    case 2:
			//	    bi = 0xff00ffff | (_poseIndex << 16);
			//	    break;
			//    case 3:
			//	    bi = 0x00ffffff | (_poseIndex << 24);
			//	    break;
		    //}
	    }
    }

	return bi;
}

// get the body-index value of the given landmark coordinates
uint GetBodyIndexOfLandmark(uint2 id, float4 lmPos, uint bodyIndex, int halfSize, uint biShift, uint biMask)
{
	int lmX = (int)round((_DepthScaleX >= 0.0 ? lmPos.x : 1.0 - lmPos.x) * _BodyIndexImgWidth);
	int lmY = (int)round(lmPos.y * _BodyIndexImgHeight);

    uint bi = 0xffffffff;
    int2 iid = (int2)id;

	if (iid.x >= (lmX - halfSize) && iid.x <= (lmX + halfSize) && iid.y >= (lmY - halfSize) && iid.y <= (lmY + halfSize))
	{
        bi = (bodyIndex << biShift) | biMask;

		//switch (id.x & 3)
		//{
		//	case 0:
		//		bi = 0xffffff00 | bodyIndex;
		//		break;
		//	case 1:
		//		bi = 0xffff00ff | (bodyIndex << 8);
		//		break;
		//	case 2:
		//		bi = 0xff00ffff | (bodyIndex << 16);
		//		break;
		//	case 3:
		//		bi = 0x00ffffff | (bodyIndex << 24);
		//		break;
		//}
	}

	return bi;
}

// get the body index of the given coordinates or lm coordinates
uint GetBodyIndexAll(uint2 id, uint biShift, uint biMask)
{
    // position
    uint bi = GetBodyIndexOf(id.x, id.y, biShift, biMask);

    // landmarks
    for(uint i1 = 0; i1 < 33; i1++)  // _lmCount
    {
        float4 lm = _landmarkOutput[i1];
        lm.y = 1 - lm.y;

        uint bi2 = GetBodyIndexOfLandmark(id, lm, 5, i1 == 23 || i1 == 24 || i1 == 11 || i1 == 12 ? 4 : 2, biShift, biMask);
        bi = bi2 != 0xffffffff ? bi2 : bi;
    }

    // special landmarks
    for(uint i2 = 33; i2 < _lmCount; i2++)  // 
    {
        float4 lm = _landmarkOutput[i2];
        lm.y = 1 - lm.y;

        uint bi2 = GetBodyIndexOfLandmark(id, lm, 4, 2, biShift, biMask);
        bi = bi2 != 0xffffffff ? bi2 : bi;
    }

    //// center
    //const PoseDetection pd = _poseDetections[0];
    //float4 lmCenter = float4(pd.keyPoints[0], 0, 0);
    
    //uint bi3 = GetBodyIndexOfLandmark(id, lmCenter, 6, 4, biShift, biMask);
    //bi = bi3 != 0xffffffff ? bi3 : bi;

    //// shoulder
    //float4 lmShoulder = float4(pd.keyPoints[2], 0, 0);
    
    //uint bi4 = GetBodyIndexOfLandmark(id, lmShoulder, 7, 4, biShift, biMask);
    //bi = bi4 != 0xffffffff ? bi4 : bi;

    return bi;
}

[numthreads(8, 8, 1)]
void SegmTexToBodyIndexBuffer(uint3 id : SV_DispatchThreadID)
{
    float lmScore = _LandmarkWorldBuf[_lmCount].x;
	if ((id.x & 3) == 0 && lmScore >= _lmThreshold)
	{
		uint bi0 = GetBodyIndexOf(id.x, id.y, 0, 0xffffff00);  // GetBodyIndexAll
		uint bi1 = GetBodyIndexOf(id.x + 1, id.y, 8, 0xffff00ff);  // GetBodyIndexAll
		uint bi2 = GetBodyIndexOf(id.x + 2, id.y, 16, 0xff00ffff);  // GetBodyIndexAll
		uint bi3 = GetBodyIndexOf(id.x + 3, id.y, 24, 0x00ffffff);  // GetBodyIndexAll

        uint biPrev = _BodyIndexBuf[(id.x + id.y * _BodyIndexImgWidth) >> 2];
        uint bi0p = (biPrev & 0xff) | 0xffffff00;
        uint bi1p = (biPrev & 0xff00) | 0xffff00ff;
        uint bi2p = (biPrev & 0xff0000) | 0xff00ffff;
        uint bi3p = (biPrev & 0xff000000) | 0x00ffffff;

        bi0 = bi0p != 0xffffffff ? bi0p : bi0;
        bi1 = bi1p != 0xffffffff ? bi1p : bi1;
        bi2 = bi2p != 0xffffffff ? bi2p : bi2;
        bi3 = bi3p != 0xffffffff ? bi3p : bi3;

		_BodyIndexBuf[(id.x + id.y * _BodyIndexImgWidth) >> 2] = bi0 & bi1 & bi2 & bi3;
	}
}


